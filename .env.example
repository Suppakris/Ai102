# ─────────────────────────────────────────────────────────────
# Ai102 — environment variables
# Copy this file to `.env` (local) or add these in Vercel →
# Settings → Environment Variables (Production + Preview).
# ─────────────────────────────────────────────────────────────

# ══ REQUIRED — the only thing you must set ═════════════════════

# Postgres connection string (used at runtime AND for migrations).
# Supabase: Project Settings → Database → Connection string →
#   use the TRANSACTION POOLER (port 6543), not Session pooler or Direct
#   connection. This app runs on Vercel serverless functions, which can
#   have several instances warm at once; Session/Direct connections are
#   held for the life of the client and exhaust a pooler's small
#   max-clients limit fast. Transaction mode releases the connection
#   after each query, which is what serverless needs. Copy the whole
#   connection string Supabase gives you (don't reuse an old username —
#   the pooler requires the project-ref-qualified `postgres.<ref>` user).
# Neon also works (use its pooled connection string, `-pooler` in the host).
# Must be a full postgres:// URL. Must also be set in Vercel env vars.
DATABASE_URL=""

# Session signing key. Generate one:  openssl rand -base64 32
NEXTAUTH_SECRET=""

# The deployed URL (no trailing slash).
# Local:  http://localhost:3000
# Vercel: https://<your-project>.vercel.app
NEXTAUTH_URL=""

# GitHub OAuth login (free, no billing/card required).
# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App.
# Authorization callback URL must be:
#   <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ══ OPTIONAL — leave blank; features degrade gracefully ════════

# Google OAuth login (free — no billing/card required just to sign
# users in; only paid Google APIs need billing enabled).
# console.cloud.google.com → APIs & Services → Credentials →
#   Create Credentials → OAuth client ID → Web application.
# Authorization callback URL must be:
#   <NEXTAUTH_URL>/api/auth/callback/google
# Leave both blank to hide the "Sign in with Google" button.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Discord OAuth login (free, no billing/card required).
# discord.com/developers/applications → New Application → OAuth2.
# Redirect must be:
#   <NEXTAUTH_URL>/api/auth/callback/discord
# Leave both blank to hide the "Sign in with Discord" button.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# LLM key. NOT required: users bring their own key in the app's
# Settings → "AI Provider & API Key" (Groq's free tier works).
OPENAI_API_KEY=""

# Optional Ollama base URL for a remote/tunneled instance (for example via ngrok).
# Leave blank to use the default localhost endpoint.
OLLAMA_BASE_URL=""

# Override the default Ollama model (default: llama3.2:3b).
OLLAMA_DEFAULT_MODEL=""

# Ollama context window in tokens (default: 8192). Ollama's own default
# (often 2048) is smaller than this app's generation system prompt, which
# makes the model see truncated instructions and produce broken decks.
# Lower this only if generation requests start hitting the platform's
# request-duration limit on slow/CPU-only hardware.
OLLAMA_NUM_CTX=""

# Max output tokens per Ollama generation request. Unset by default (no
# cap is sent, so Ollama's own behavior applies). Same trade-off as
# OLLAMA_NUM_CTX above: more tokens allowed means more time needed.
OLLAMA_MAX_OUTPUT_TOKENS=""

# AI image generation is free by default via Pollinations.ai (image.pollinations.ai) —
# no API key needed, nothing to set here for images to work.

# Optional, paid, admin-only upgrade path (https://fal.ai, Flux models).
# Leave unset to keep image generation on the free Pollinations path.
FAL_API_KEY=""

# Legacy/unused paid path (Together AI). Not wired into any active feature.
TOGETHER_AI_API_KEY=""

# Optional, paid, opt-in TEXT generation upgrade (https://openrouter.ai).
# Text generation defaults to the free local Ollama server; setting this key
# adds an "OpenRouter (paid)" group to the model picker with 6 preset cloud
# models (see src/constants/text-models.ts) that everyone can select —
# whoever owns this key gets billed per token by OpenRouter, not the app.
# Leave blank to keep text generation Ollama-only.
OPENROUTER_API_KEY=""

# Stock photos (https://unsplash.com/developers).
UNSPLASH_ACCESS_KEY=""

# Google Custom Search image lookup (https://programmablesearchengine.google.com).
GOOGLE_CUSTOM_SEARCH_API_KEY=""
SEARCH_ENGINE_CX=""

# Web search for outlines and the in-editor chat agent (https://tavily.com).
TAVILY_API_KEY=""
