generator client {
  provider        = "prisma-client"
  output          = "../prisma/generated"
  runtime         = "edge-light"
  previewFeatures = ["relationJoins"]
}

generator client_migrate {
  provider        = "prisma-client"
  output          = "../prisma/local/generated"
  runtime         = "nodejs"
  previewFeatures = ["relationJoins"]
}

datasource db {
  // Prisma 7: connection URLs are NOT allowed here. The runtime connection
  // is configured via a driver adapter in src/server/db.ts (env.DATABASE_URL);
  // the migration URL lives in prisma.config.ts.
  provider = "postgresql"
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id                         String                      @id @default(cuid())
  name                       String?
  email                      String?                     @unique
  password                   String?
  emailVerified              DateTime?
  image                      String?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @default(now()) @updatedAt
  headline                   String?                     @db.VarChar(100)
  bio                        String?                     @db.Text
  interests                  String[]
  location                   String?
  website                    String?
  role                       UserRole                    @default(USER)
  hasAccess                  Boolean                     @default(false)
  accounts                   Account[]
  documents                  BaseDocument[]
  favorites                  FavoriteDocument[]
  generatedImages            GeneratedImage[]
  uploadedFiles              UploadedFile[]
  presentationThemes         PresentationTheme[]
  favoritePresentationThemes FavoritePresentationTheme[]
  presentationThemeLikes     PresentationThemeLike[]
  fontPairs                  FontPair[]
  memberships                TenantMembership[]
  documentsCreated           BaseDocument[]              @relation("DocumentCreatedBy")
  documentsUpdated           BaseDocument[]              @relation("DocumentUpdatedBy")
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

// A tenant is a workspace resources belong to. Every user gets a personal
// tenant (created lazily on first use — see src/server/tenant.ts) so single-
// user data keeps working unchanged; users can additionally belong to
// shared/team tenants via TenantMembership.
model Tenant {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  isPersonal  Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  memberships TenantMembership[]
  documents   BaseDocument[]
  themes      PresentationTheme[]
  fontPairs   FontPair[]
}

model TenantMembership {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

enum DocumentType {
  NOTE
  DOCUMENT
  DRAWING
  DESIGN
  STICKY_NOTES
  MIND_MAP
  RESEARCH_PAPER
  FLIPBOOK
  PRESENTATION
}

model BaseDocument {
  id           String             @id @default(cuid())
  title        String
  type         DocumentType
  userId       String
  tenantId     String
  // Ownership audit trail: userId above is the *current* owner (can be
  // reassigned within a tenant); these two are immutable/append-only
  // records of who authored and who last touched the row.
  createdById  String
  updatedById  String
  thumbnailUrl String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  isPublic     Boolean            @default(false)
  documentType String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy    User               @relation("DocumentCreatedBy", fields: [createdById], references: [id])
  updatedBy    User               @relation("DocumentUpdatedBy", fields: [updatedById], references: [id])
  presentation Presentation?
  favorites    FavoriteDocument[]

  @@index([tenantId])
}

model Presentation {
  id                String                @id @default(cuid())
  content           Json
  theme             String                @default("mystique")
  imageSource       String?               @default("ai")
  prompt            String?
  presentationStyle String?
  customization     Json?
  language          String?               @default("en-US")
  outline           String[]
  searchResults     Json?
  toolCalls          Json?
  selectedChunks     Json?
  templateId        String?
  base              BaseDocument          @relation(fields: [id], references: [id], onDelete: Cascade)
}

model PresentationTheme {
  id                         String                      @id @default(cuid())
  name                       String
  description                String?
  userId                     String
  tenantId                   String
  logoUrl                    String?
  isPublic                   Boolean                     @default(false)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  isAdmin                    Boolean                     @default(false)
  themeData                  Json
  user                       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  favoritePresentationThemes FavoritePresentationTheme[]
  presentationThemeLikes     PresentationThemeLike[]

  @@index([userId])
  @@index([tenantId])
  @@map("CustomTheme")
}

model FavoritePresentationTheme {
  id        String            @id @default(cuid())
  userId    String
  themeId   String
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     PresentationTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([userId, themeId])
  @@index([userId])
  @@index([themeId])
}

model PresentationThemeLike {
  id        String            @id @default(cuid())
  userId    String
  themeId   String
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     PresentationTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([userId, themeId])
  @@index([userId])
  @@index([themeId])
}

model FontPair {
  id            String   @id @default(cuid())
  heading       String
  headingUrl    String?
  headingWeight Int      @default(700)
  body          String
  bodyUrl       String?
  bodyWeight    Int      @default(400)
  userId        String
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model FavoriteDocument {
  id         String       @id @default(uuid())
  documentId String
  userId     String
  document   BaseDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
}

// Tracks activity on the presentation-editing agent's LangGraph thread
// (thread_id == BaseDocument.id, see src/ai/agents/presentation/createAgent.ts
// and src/ai/lib/postgres.ts). The actual conversation/checkpoint state lives
// in Postgres tables LangGraph itself manages (checkpoints, checkpoint_blobs,
// checkpoint_writes) and grows without bound as a presentation is edited —
// this row is just what lets the pruning job (src/ai/lib/prune-checkpoints.ts)
// find threads that have gone stale, without scanning LangGraph's tables.
model AgentThread {
  threadId     String   @id
  lastActiveAt DateTime @default(now())

  @@index([lastActiveAt])
}

model GeneratedImage {
  id        String   @id @default(cuid())
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  prompt    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// User-uploaded file bytes (slide images, custom fonts, source documents),
// served back by GET /api/files/[id].
//
// Bytes live in Postgres rather than on disk because the app's deployment
// target (Vercel) has an ephemeral, read-only filesystem — files written to a
// folder would survive locally and then silently vanish on every redeploy.
// Object storage would be the conventional choice at scale; this keeps the
// project on free infrastructure with no third-party account. Images are
// shrunk client-side before they get here, so rows stay small.
model UploadedFile {
  id        String   @id @default(cuid())
  data      Bytes
  mimeType  String
  size      Int
  name      String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Audit reports produced by the slide verification pipeline
// (POST /api/presentation/audit-slide) — one row per audit round.
model SlideAudit {
  id            String   @id @default(cuid())
  slideId       String
  round         Int      @default(0)
  score         Int?
  pass          Boolean  @default(false)
  claims        Json?
  revisionNotes Json?    @map("revision_notes")
  reviewerNotes Json?    @map("reviewer_notes")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([slideId])
}
